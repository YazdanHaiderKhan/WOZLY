# ═══════════════════════════════════════════════════════════════════════════════
#  WOZLY — Environment Configuration
#  Copy this file to .env and fill in your values.
#  For a college demo, GitHub Models is FREE and works great.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider (pick ONE) ───────────────────────────────────────────────────
# Options: github | groq | gemini | openai
LLM_PROVIDER=github

# ── Option 1: GitHub Models (RECOMMENDED — FREE) ─────────────────────────────
# 1. Go to: github.com → Settings → Developer Settings → Personal Access Tokens
# 2. Create a new Fine-grained token (default read permissions are enough)
# 3. Paste it below
GITHUB_TOKEN=github_pat_your_token_here

# GitHub Models supports: gpt-4o, gpt-4o-mini, Llama-3, Mistral, etc.
OPENAI_MODEL_TUTOR=gpt-4o
OPENAI_MODEL_ROADMAP=gpt-4o
OPENAI_MODEL_PROFILE=gpt-4o-mini
OPENAI_MODEL_ASSESSMENT=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Option 2: Groq (FREE — groq.com/keys) ─────────────────────────────────────
# Very fast inference. Uses Llama 3 / Mixtral. No credit card needed.
# GROQ_API_KEY=gsk_your_groq_key_here

# ── Option 3: Google Gemini (FREE — aistudio.google.com) ──────────────────────
# GEMINI_API_KEY=AIza_your_gemini_key_here

# ── Option 4: OpenAI (paid — platform.openai.com) ─────────────────────────────
# OPENAI_API_KEY=sk-proj-...

# ── Web Search Fallback (FREE tier at app.tavily.com) ────────────────────────
# Optional — only used when ChromaDB retrieval confidence < 0.7
TAVILY_API_KEY=tvly-your_tavily_key_here

# ── Database (auto-configured by Docker Compose — don't change) ──────────────
DATABASE_URL=postgresql+asyncpg://wozly:wozlypass@postgres:5432/wozlydb
POSTGRES_USER=wozly
POSTGRES_PASSWORD=wozlypass
POSTGRES_DB=wozlydb

# ── ChromaDB (auto-configured by Docker Compose — don't change) ──────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret-minimum-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Agent Tuning ──────────────────────────────────────────────────────────────
ALPHA=0.3
MAX_HINTS_PER_TOPIC=5
RAG_TOP_K=5
RAG_MIN_CONFIDENCE=0.7
